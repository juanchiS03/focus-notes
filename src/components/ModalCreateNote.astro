<div
    id="modal-new-note"
    class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-999 hidden items-center justify-center p-4"
>
    <div
        class="bg-white w-full max-w-md rounded-2xl shadow-2xl overflow-hidden transform transition-all"
    >
        <div class="p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-slate-900">
                    Crear nueva nota
                </h3>
                <button
                    id="close-modal"
                    class="text-slate-400 hover:text-slate-600"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path></svg
                    >
                </button>
            </div>

            <form id="form-new-note" class="space-y-4">
                <input type="hidden" id="edit-note-id" value="" />
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1"
                        >Título</label
                    >
                    <input
                        type="text"
                        id="note-title"
                        required
                        class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-950 outline-none"
                        placeholder="¿Sobre qué es esto?"
                    />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1"
                        >Contenido</label
                    >
                    <textarea
                        id="note-content"
                        required
                        rows="4"
                        class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-slate-950 outline-none resize-none"
                        placeholder="Escribe tu idea aquí..."></textarea>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1"
                        >Tag</label
                    >
                    <select
                        id="note-tag"
                        class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-brand outline-none text-slate-600"
                    >
                        <option value="">Sin etiqueta</option>
                        <option value="Trabajo">Trabajo</option>
                        <option value="Personal">Personal</option>
                        <option value="Idea">Idea</option>
                        <option value="Urgente">Urgente</option>
                    </select>
                </div>

                <div class="flex space-x-3 pt-2">
                    <button
                        type="button"
                        id="btn-cancel"
                        class="flex-1 px-4 py-2 text-sm font-semibold text-slate-700 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors"
                        >Cancelar</button
                    >
                    <button
                        type="submit"
                        class="flex-1 px-4 py-2 text-sm font-semibold text-white bg-slate-950 rounded-lg hover:bg-slate-800 transition-colors"
                        >Guardar Nota</button
                    >
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    console.log("Modal cargado y escuchando eventos...");
    // IMPORTANTE: Al ser un componente, este script se ejecutará en la página donde lo uses.
    const modal = document.getElementById("modal-new-note");
    const form = document.getElementById("form-new-note");
    const cancelBtn = document.getElementById("btn-cancel");

    // Escuchamos un evento personalizado para editar una nota desde cualquier sitio
    document.addEventListener("open-edit-modal", (e: any) => {
        const noteData = e.detail; // Esperamos que envíen los datos de la nota a editar

        (document.getElementById("edit-note-id") as HTMLInputElement).value =
            noteData.id || "";
        // Aquí podrías rellenar el formulario con los datos de la nota para editar
        (document.getElementById("note-title") as HTMLInputElement).value =
            noteData.title || "";
        (document.getElementById("note-content") as HTMLTextAreaElement).value =
            noteData.content || "";
        (document.getElementById("note-tag") as HTMLSelectElement).value =
            noteData.tag || "";

        modal?.classList.remove("hidden");
        modal?.classList.add("flex"); // Añadimos flex aquí para que se centre
    });

    // Escuchamos un evento personalizado para abrir el modal desde cualquier sitio
    document.addEventListener("open-note-modal", () => {
        // IMPORTANTE: Limpiamos el ID oculto para que no se quede "pegado"
        const editIdInput = document.getElementById(
            "edit-note-id",
        ) as HTMLInputElement;
        if (editIdInput) editIdInput.value = "";

        modal?.classList.replace("hidden", "flex");
        console.log("Modal escuchando: Abriendo...");
        modal?.classList.remove("hidden");
        modal?.classList.add("flex"); // Añadimos flex aquí para que se centre
    });

    // Función para cerrar (reutilizable)
    const hideModal = () => {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
    };

    cancelBtn?.addEventListener("click", hideModal);

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        // 1. Leemos el ID del "escondite" (el input oculto)
        const editIdInput = document.getElementById(
            "edit-note-id",
        ) as HTMLInputElement;
        const noteId = editIdInput.value;

        const title = (
            document.getElementById("note-title") as HTMLInputElement
        ).value;
        const content = (
            document.getElementById("note-content") as HTMLTextAreaElement
        ).value;
        const tag = (document.getElementById("note-tag") as HTMLSelectElement)
            .value;

        const isEdit = noteId !== "";

        // Si hay ID, la URL termina en /ID. Si no, va a la raíz.
        const url = isEdit
            ? `${import.meta.env.PUBLIC_API_URL}/notes/${noteId}`
            : `${import.meta.env.PUBLIC_API_URL}/notes`;

        // Si hay ID usamos PUT. Si no, usamos POST.
        const method = isEdit ? "PUT" : "POST";

        try {
            const res = await fetch(url, {
                method,
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ title, content, tag }),
            });

            if (res.ok) {
                window.location.reload(); // Refrescar para ver la nueva nota
            }
        } catch (err) {
            console.error("Error guardando nota:", err);
        }
    });

    // Añade esta referencia arriba
    const closeBtn = document.getElementById("close-modal");

    // Y este listener
    closeBtn?.addEventListener("click", () => {
        modal?.classList.add("hidden");
    });

    // Cerrar también si hacen clic fuera (en el fondo oscuro)
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) modal.classList.add("hidden");
    });
</script>
