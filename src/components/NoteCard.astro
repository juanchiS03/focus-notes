---
// src/components/NoteCard.astro
const { id, title, content, createdAt } = Astro.props;
---

<div class="bg-white border border-slate-200 p-5 rounded-2xl shadow-sm hover:shadow-md transition-all group relative">
    <button 
        class="delete-btn absolute top-4 right-4 text-slate-300 hover:text-red-600 transition-colors opacity-60 group-hover:opacity-100"
        data-id={id}
        title="Borrar nota"
    >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
    </button>

    <h3 class="text-lg font-bold text-slate-900 mb-2 pr-8">{title}</h3>
    <p class="text-slate-600 text-sm line-clamp-4">{content}</p>
    
    <div class="mt-4 pt-3 border-t border-slate-50 text-xs text-slate-400">
        {new Date(createdAt).toLocaleDateString()}
    </div>
</div>