---
// src/components/NoteCard.astro
const { id, title, content, createdAt, favourite, tag } = Astro.props;

const tagStyles: any = {
    Trabajo: "bg-blue-50 border-blue-200 text-blue-700",
    Personal: "bg-green-50 border-green-200 text-green-700",
    Idea: "bg-purple-50 border-purple-200 text-purple-700",
    Urgente: "bg-red-50 border-red-200 text-red-700",
};

// Si el tag no existe en el diccionario, usamos uno por defecto (gris)
const currentStyle =
    tagStyles[tag] || "bg-slate-50 border-slate-200 text-slate-600";
---

<div
    class="note-card bg-white border border-slate-200 p-5 rounded-2xl shadow-sm hover:shadow-md transition-all group relative flex flex-col h-full"
    data-id={id}
    data-tag={tag}
>
    <div class="absolute top-4 right-4 flex items-center space-x-1">
        <button
            type="button"
            data-id={id}
            class="favourite-btn p-1.5 rounded-full transition-colors focus:outline-none"
        >
            <svg
                class={`w-5 h-5 transition-colors ${favourite ? "fill-red-500 text-red-500 hover:text-black" : "fill-none text-slate-300 hover:text-red-400"}`}
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12.01 6.001C6.5 1 1 8 5.782 13.001L12.011 20l6.23-7C23 8 17.5 1 12.01 6.002Z"
                ></path>
            </svg>
        </button>

        <button
            class="delete-btn p-1.5 text-slate-300 hover:text-red-600 transition-colors opacity-60 group-hover:opacity-100"
            data-id={id}
            title="Borrar nota"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                ></path>
            </svg>
        </button>
    </div>

    <div class="pr-16 mb-2">
        <h3 class="text-lg font-bold text-slate-900 leading-tight">
            {title}
        </h3>
    </div>

    <p class="text-slate-600 text-sm line-clamp-4 flex-1">
        {content}
    </p>

    {
        tag && (
            <span
                class={`inline-flex items-center border text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wide mt-4 w-fit ${currentStyle}`}
            >
                {tag}
            </span>
        )
    }

    <div
        class="mt-4 pt-3 border-t border-slate-50 text-[10px] font-medium uppercase tracking-wider text-slate-400"
    >
        {new Date(createdAt).toLocaleDateString()}
    </div>
</div>
